VACUUM FULL t_table;
-- just to load pages
set enable_seqscan = off;
SELECT * FROM t_table WHERE val >= 5;
 id | val | val2 
----+-----+------
  5 |   5 |    5
  6 |   6 |    6
  7 |   7 |    7
  8 |   8 |    8
  9 |   9 |    9
 10 |  10 |   10
(6 rows)

SELECT * FROM t_table WHERE val2 = 6;
 id | val | val2 
----+-----+------
  6 |   6 |    6
(1 row)


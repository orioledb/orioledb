                           Filter: (val_1 = 1)
               ->  Gather
                     Workers Planned: 1
                     ->  Parallel Seq Scan on o_test_parallel_seq_rescan_multiple_joins2 ot2
                           Filter: (val_1 = 1)
         ->  Gather
               Workers Planned: 1
               ->  Parallel Seq Scan on o_test_parallel_seq_rescan_multiple_joins3 ot3
                     Filter: (val_1 = 1)

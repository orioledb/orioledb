#!/usr/bin/env bash

set -euo pipefail

usage() {
	echo "Usage: $0 [--push] [CONFIG ...]"
	echo
	echo "Build a config image from config/docker-compose.base.yaml"
	echo "and optional config directories (for example, setup/s3)."
	echo
	echo "  --push  Push the built config image"
}

push=false
configs=()
for arg in "$@"; do
	case "$arg" in
	-h | --help)
		usage
		exit 0
		;;
	--push)
		push=true
		;;
	*)
		configs+=("$arg")
		;;
	esac
done

mkdir -p target
config/make-compose "${configs[@]}" >target/docker-compose.yaml

image="$(config/print-config-image "${configs[@]}")"

docker build --platform "linux/amd64" -f config/Dockerfile -t "$image" .
if [[ "$push" == true ]]; then
	docker push "$image"
fi

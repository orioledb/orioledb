#!/bin/sh
set -eu

jdwp_option=
if [ -n "${JEPSEN_JDWP_PORT:-}" ]; then
	case "$JEPSEN_JDWP_PORT" in
	*[!0-9]*)
		echo "JEPSEN_JDWP_PORT must be a number" >&2
		exit 2
		;;
	esac
	if [ "$JEPSEN_JDWP_PORT" -lt 1 ] || [ "$JEPSEN_JDWP_PORT" -gt 65535 ]; then
		echo "JEPSEN_JDWP_PORT must be between 1 and 65535" >&2
		exit 2
	fi
	jdwp_option="-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=127.0.0.1:${JEPSEN_JDWP_PORT}"
fi

(
	if [ -n "${JEPSEN_SUPPRESS_STDOUT:-}" ]; then
		exec >/dev/null
	fi

	java \
		${jdwp_option:+"$jdwp_option"} \
		-Djava.awt.headless=true \
		-server \
		-jar /opt/jepsen/jepsen-postgres.jar \
		test-all \
		--test-count 1 \
		--no-ssh \
		--workload "$JEPSEN_WORKLOAD" \
		--isolation "$JEPSEN_ISOLATION" \
		--expected-consistency-model "$JEPSEN_EXPECTED_CONSISTENCY_MODEL" \
		--concurrency "$JEPSEN_CONCURRENCY" \
		--max-writes-per-key "$JEPSEN_MAX_WRITES_PER_KEY" \
		--rate "$JEPSEN_RATE" \
		--time-limit "$JEPSEN_TIME_LIMIT" \
		--nemesis "$JEPSEN_NEMESIS" \
		--node "$JEPSEN_NODE" \
		--existing-postgres \
		--postgres-user "$JEPSEN_POSTGRES_USER" \
		--postgres-password "$JEPSEN_POSTGRES_PASSWORD" \
		--postgres-port "$JEPSEN_POSTGRES_PORT" \
		"$@"
)

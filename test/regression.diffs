-SELECT relname, relkind, reloptions
-FROM pg_class
-WHERE relname = 'o_test_replace_view';
-       relname       | relkind | reloptions 
----------------------+---------+------------
- o_test_replace_view | v       | 
-(1 row)
-
-SELECT * FROM o_test_replace_view ORDER BY i;

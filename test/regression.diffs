-SELECT
-	relname,
-	CASE 
-		WHEN reloftype = 0 THEN 'regular'
-		ELSE 'typed'
-	END AS reloftype,
-	relkind
-FROM pg_class
-WHERE relname = 'o_test_regular_table';
